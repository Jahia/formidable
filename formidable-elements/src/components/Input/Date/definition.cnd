// Date input component properties
// Note: Currently defaultValue, min and max are defined as date type,
// so "today" keyword handling is not possible.
// To support this, these props should be defined as string type
[fmdb:inputDate] > jnt:content, fmdbmix:element
 - required (boolean) = false
 - defaultValue (date, DatePicker)
 - min (date, DatePicker)
 - max (date, DatePicker)
 - step (long)
