// Button input component properties
// Note: Button inputs are used for form actions like submit, reset, or custom actions
[fmdb:inputButton] > jnt:content, fmdbmix:element
 - buttonType (string, choicelist[resourceBundle]) = 'button' < 'button', 'submit', 'reset'
 - variant (string, choicelist[resourceBundle]) = 'primary' < 'primary', 'secondary', 'danger'

