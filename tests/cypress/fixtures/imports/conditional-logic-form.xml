<?xml version="1.0" encoding="UTF-8"?>
<FORM_NAME_PLACEHOLDER
	xmlns:fmdb="http://www.jahia.org/jahia/fmdb/nt/1.0"
	xmlns:fmdbmix="http://www.jahia.org/jahia/fmdb/mix/1.0"
	xmlns:j="http://www.jahia.org/jahia/1.0"
	xmlns:jcr="http://www.jcp.org/jcr/1.0"
	xmlns:jnt="http://www.jahia.org/jahia/nt/1.0"
	jcr:primaryType="fmdb:form">
	<j:translation_en
		jcr:language="en"
		jcr:primaryType="jnt:translation"
		jcr:title="FORM_TITLE_PLACEHOLDER"
		submitBtnLabel="Submit"/>
	<fields jcr:primaryType="fmdb:fieldList">
		<role jcr:primaryType="fmdb:radio">
			<j:translation_en
				choices="{&quot;value&quot;:&quot;admin&quot;,&quot;label&quot;:&quot;admin&quot;,&quot;selected&quot;:false} {&quot;value&quot;:&quot;editor&quot;,&quot;label&quot;:&quot;editor&quot;,&quot;selected&quot;:false}"
				jcr:language="en"
				jcr:primaryType="jnt:translation"
				jcr:title="role"/>
		</role>
		<nickname
			jcr:primaryType="fmdb:inputText"
			logics="{&quot;logicId&quot;:&quot;logic-import-role&quot;,&quot;sourceNodeId&quot;:&quot;11111111-1111-1111-1111-111111111111&quot;,&quot;sourceFieldName&quot;:&quot;role&quot;,&quot;sourceFieldType&quot;:&quot;fmdb:radio&quot;,&quot;operator&quot;:&quot;in&quot;,&quot;values&quot;:[&quot;admin&quot;]}">
			<j:translation_en
				jcr:language="en"
				jcr:primaryType="jnt:translation"
				jcr:title="nickname"/>
			<logicsSrc jcr:primaryType="fmdb:logicList">
				<logic-import-role
					jcr:primaryType="fmdb:logicSrc"
					logicNodeSource="#/fields/role"/>
			</logicsSrc>
		</nickname>
	</fields>
	<actions jcr:primaryType="fmdb:actionList"/>
</FORM_NAME_PLACEHOLDER>
