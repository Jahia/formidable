{
  "extends": "../tsconfig.json",
  "include": [
    "e2e/**/*.ts",
    "page-object/**/*.ts",
    "support/**/*.ts",
    "support/**/*.js"
  ],
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": false,
    "moduleResolution": "node",
    "noEmit": true,
    "isolatedModules": false,
    "types": [
      "cypress",
      "node",
      "cypress-iframe",
      "cypress-real-events",
      "@4tw/cypress-drag-drop",
      "cypress-wait-until",
      "@jahia/cypress"
    ],
    "lib": [
      "es2022",
      "dom",
      "dom.iterable"
    ],
    "skipLibCheck": true
  }
}
